# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
*.test
*.out

# Go workspace file
go.work

# Dependency directories
vendor/

# Build output
deskgo-*
!scripts/deskgo-autostart.sh
!scripts/deskgo-autostart.ps1
relay-server
downloads/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment files
.env
.env.local

# Temporary files
tmp/
temp/

# Code signing certificates (keep private keys secure)
scripts/certs/*.pfx
scripts/certs/*.key
scripts/certs/*.p12
scripts/certs/private.key
scripts/certs/certificate.pfx
scripts/certs/certificate.p12

# Allow public certificates to be committed
!scripts/certs/*.cer
